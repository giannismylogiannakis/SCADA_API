SCADA_BASE_URL=your_base_url
SCADA_USERNAME=your_username
SCADA_PASSWORD=your_password
SCADA_REQUEST_TIMEOUT_SECONDS=10
# Email notifications for critical static thresholds only.
EMAIL_NOTIFICATIONS_SMTP_HOST=smtp.gmail.com
EMAIL_NOTIFICATIONS_SMTP_PORT=587
EMAIL_NOTIFICATIONS_SMTP_USERNAME=oakae.data@gmail.com
EMAIL_NOTIFICATIONS_SMTP_PASSWORD=
EMAIL_NOTIFICATIONS_FROM=oakae.data@gmail.com
EMAIL_NOTIFICATIONS_USE_TLS=true
EMAIL_NOTIFICATIONS_SUBJECT_PREFIX=Rapid SCADA
# Background watcher for critical static threshold alarms.
# Checks live values and sends email even if no dashboard page is open.
CRITICAL_ALARM_WATCHER_ENABLED=true
CRITICAL_ALARM_WATCHER_INTERVAL_SECONDS=5